  m_Name:
  m_EditorClassIdentifier:
  m_Material: {fileID: 2100000, guid: 7e990d1365d386b45b8ee447b6620578, type: 2}
  m_Color: {r: 0.15686275, g: 0.29803923, b: 0.45490196, a: 1}
